{
  "name": "qmux",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dev:site": "tsx watch web/server.tsx",
    "dev:tauri": "tauri dev",
    "build": "scripts/build.sh",
    "build:site:frontend": "tsc && vite build",
    "build:site:server": "tsc -p web/tsconfig.json && esbuild web/server.tsx --bundle --packages=external --platform=node --format=esm --target=node20 --outfile=dist-site/server.mjs",
    "start:site": "node dist-site/server.mjs",
    "format": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "test:app-shortcuts": "node scripts/test-app-shortcuts.mjs",
    "test:terminal-attention": "node scripts/test-terminal-attention.mjs",
    "test:native-terminal-keyboard": "node scripts/test-native-terminal-keyboard.mjs",
    "test:composer-slash-commands": "node scripts/test-composer-slash-commands.mjs",
    "test:home-rails": "node scripts/test-home-rails.mjs",
    "test:claude-turns": "node scripts/test-claude-turns.mjs",
    "test:pane-splits": "node scripts/test-pane-splits.mjs",
    "test:research-highlights": "node scripts/test-research-highlights.mjs",
    "test:research-navigation": "node scripts/test-research-navigation.mjs",
    "test:research-events": "node scripts/test-research-events.mjs",
    "test:research-history": "node scripts/test-research-history.mjs",
    "test:research-folders": "node scripts/test-research-folders.mjs",
    "test:research-documents": "node scripts/test-research-documents.mjs",
    "test:research-conversations": "node scripts/test-research-conversations.mjs",
    "test:research-threads": "node scripts/test-research-threads.mjs",
    "test:image-markers": "node scripts/test-image-markers.mjs",
    "test:markdown-math": "node --import tsx --test tests/markdownMath.test.ts",
    "test:tagged-instructions": "node scripts/test-tagged-instructions.mjs",
    "test:research-instruction-setting": "node scripts/test-research-instruction-setting.mjs",
    "test:thread-graph-overlay": "node scripts/test-thread-graph-overlay.mjs",
    "test:workspace-scope": "node scripts/test-workspace-scope.mjs",
    "test:turn-timeline": "node scripts/test-turn-timeline.mjs",
    "test:publication": "node --import tsx --test tests/publication.test.ts tests/publicationComments.test.ts web/server.test.ts web/comments.test.ts",
    "test:opencode-plugin": "node --experimental-default-type=module --test qmux-opencode-plugin/tests/*.test.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@viz-js/viz": "^3.28.0",
    "dompurify": "^3.3.3",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-mathjax": "^7.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
