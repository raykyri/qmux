diff --git a/Sources/GhosttyTerminal/Platform/Shared/TerminalMainActor.swift b/Sources/GhosttyTerminal/Platform/Shared/TerminalMainActor.swift
index 41783dd..fe34d23 100644
--- a/Sources/GhosttyTerminal/Platform/Shared/TerminalMainActor.swift
+++ b/Sources/GhosttyTerminal/Platform/Shared/TerminalMainActor.swift
@@ -19,0 +20,20 @@ func terminalRunOnMain(
+
+/// Executes a callback on the main actor without returning to libghostty until
+/// its handled result is known. Action payload pointers are borrowed for the
+/// duration of the C callback, so this must remain synchronous.
+@inline(__always)
+func terminalCallOnMain<Result: Sendable>(
+    _ operation: @escaping @MainActor () -> Result
+) -> Result {
+    if Thread.isMainThread {
+        return MainActor.assumeIsolated {
+            operation()
+        }
+    }
+
+    return DispatchQueue.main.sync {
+        MainActor.assumeIsolated {
+            operation()
+        }
+    }
+}
