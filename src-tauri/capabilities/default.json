{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the qmux application window.",
  "windows": ["main", "global-task-launcher"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-hide",
    "clipboard-manager:allow-write-text"
  ]
}
